# Database
POSTGRES_DB=api_sentinel
POSTGRES_USER=api_sentinel
POSTGRES_PASSWORD=api_sentinel
DATABASE_URL=jdbc:postgresql://localhost:5432/api_sentinel
DATABASE_USERNAME=api_sentinel
DATABASE_PASSWORD=api_sentinel

# Redis is included for future rate limiting/cache work.
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_MINUTES=60

# AI provider
AI_PROVIDER=mock
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4.1-mini

# Optional local profile
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
